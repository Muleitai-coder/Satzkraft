{
  "name": "satzkraft",
  "version": "0.26.0",
  "private": true,
  "packageManager": "npm@10.9.8",
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "test:unit": "node --test tests/*.test.cjs tests/*.test.mjs",
    "test:e2e": "playwright test --config qa/playwright/playwright.config.cjs --update-snapshots=none",
    "test:e2e:functional": "playwright test --config qa/playwright/playwright.config.cjs --grep-invert @visual --update-snapshots=none",
    "test:e2e:visual": "playwright test --config qa/playwright/playwright.config.cjs --grep @visual --update-snapshots=none",
    "test:e2e:visual:update": "playwright test --config qa/playwright/playwright.config.cjs --grep @visual --update-snapshots=all",
    "test:ci": "npm run test:unit && npm run test:e2e"
  },
  "devDependencies": {
    "@playwright/test": "1.61.0"
  }
}
